  "type": "module",
  "scripts": {
    "dev": "cd backend && node server.js",
    "build": "cd frontend && vite build && cd ..\\backend && esbuild server.js --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=dist/server.mjs",
