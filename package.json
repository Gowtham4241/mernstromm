    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "mapbox-gl": "^3.24.1",
    "mongoose": "^9.7.0",
    "motion": "^12.23.24",
    "razorpay": "^2.9.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
