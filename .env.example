# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MONGODB_URI: Connection string for the remote MongoDB database/Atlas cluster.
# For example, mongodb+srv://username:password@cluster.mongodb.net/autoaid
MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/autoaid?retryWrites=true&w=majority"

# Mapbox Access Token for rendering the mechanics location map
VITE_MAPBOX_ACCESS_TOKEN="YOUR_MAPBOX_ACCESS_TOKEN"

# Razorpay payment gateway credentials
RAZORPAY_KEY_ID="YOUR_RAZORPAY_KEY_ID"
RAZORPAY_KEY_SECRET="YOUR_RAZORPAY_KEY_SECRET"
